# ============================================================================
#  Auto-Researches Lite — local single-user deployment environment
# ============================================================================
#  Copy this file to  ../.env  (next to docker-compose.yml, git-ignored), fill in
#  the few values below, then:   cd deploy && docker compose up --build -d
#
#  This file holds ONLY what the stack needs at BOOT. With no values at all the
#  app still boots and runs fully offline (SQLite, in-process job queue,
#  deterministic mock LLM). Everything else — LLM provider API keys, MinerU PDF
#  parsing, Zotero, paper-source keys, runtime knobs — is configured AFTER first
#  boot in the in-app Settings panel, never in this file.
# ----------------------------------------------------------------------------

# ---- Secret (set ONCE, then keep STABLE forever) -----------------------------
# JWT_SECRET is the credential-encryption root: a key derived from it encrypts
# every secret you later enter in the Settings panel (model API keys,
# integration keys). If you change it later, all stored secrets become
# undecryptable and must be re-entered. Generate a long random string:
#     openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional: a SEPARATE key for encrypting stored credentials, so JWT_SECRET can
# change without losing the secrets saved in Settings. Blank = use JWT_SECRET.
# Same rule: set once, keep stable.
CREDENTIAL_SECRET=

# ---- Environment ------------------------------------------------------------
# "production" or "development" (affects logging / CORS strictness).
ENVIRONMENT=production


# ============================================================================
#  Advanced — usually leave commented (sensible defaults / set by compose)
# ============================================================================

# Infrastructure — docker-compose already injects these for the bundled db/redis
# and the data volume. Override ONLY if you point at your own services.
# DATABASE_URL=postgresql+psycopg2://far:far@db:5432/far   # blank = local SQLite file
# REDIS_URL=redis://redis:6379/0                           # blank = in-process thread queue
# DATA_ROOT=/data                                          # artifact / upload storage path

# Host port the frontend is published on (compose maps 127.0.0.1:<port>:80).
# FRONTEND_PORT=8080

# Force the deterministic offline mock regardless of any keys configured in Settings.
# OFFLINE_MODE=true

# Initial worker parallelism. The LIVE value is set in Settings (0 here = use
# this default); or scale out with:  docker compose up -d --scale worker=N
# WORKER_CONCURRENCY=2
